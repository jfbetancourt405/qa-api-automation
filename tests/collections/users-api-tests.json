              "});\r",
              "\r",
              "pm.test(\"Response contains name\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.name).to.eql(\"Juan QA\");\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains email\", function () {\r",
              "    var jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.email).to.eql(\"juan@test.com\");\r",
              "});"
